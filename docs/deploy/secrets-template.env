# Copy this file and fill with real values.
# Do NOT commit real secrets.

# Spring datasource
SPRING_DATASOURCE_URL=jdbc:postgresql://<CLOUD_SQL_PUBLIC_IP>:5432/finance
SPRING_DATASOURCE_USERNAME=finance_app
SPRING_DATASOURCE_PASSWORD=

# JWT
JWT_ISSUER=family-finance-manager
JWT_SECRET=
JWT_ACCESS_TOKEN_MINUTES=60

# Password reset
PASSWORD_RESET_TOKEN_MINUTES=30
PASSWORD_RESET_URL=https://<frontend-domain>/reset-password
PASSWORD_RESET_FROM_EMAIL=no-reply@<your-domain>

# SMTP
SPRING_MAIL_HOST=smtp.sendgrid.net
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# Esempio valori (non committare mai quelli reali):
# SPRING_DATASOURCE_PASSWORD=<DB_PASSWORD>
# JWT_SECRET=<JWT_SECRET>
# SPRING_MAIL_USERNAME=<SMTP_USERNAME>
# SPRING_MAIL_PASSWORD=<SMTP_PASSWORD>
